// Prisma Schema for Nexus Gear E-commerce
// Converted from MySQL to PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==================== MODELS ====================

// User model - Customers and Admins
model User {
  id             Int         @id @default(autoincrement())
  firstName      String      @map("first_name") @db.VarChar(255)
  lastName       String?     @map("last_name") @db.VarChar(255)
  email          String      @unique @db.VarChar(255)
  phone          String      @db.VarChar(255)
  dateOfBirth    DateTime?   @map("date_of_birth") @db.Date
  gender         String?     @db.VarChar(20)
  password       String      @db.VarChar(255)
  role           String      @default("user") @db.VarChar(50)
  addressStreet  String?     @map("address_street") @db.VarChar(255)
  addressWard    String?     @map("address_ward") @db.VarChar(255)
  addressCity    String?     @map("address_city") @db.VarChar(255)
  addressCountry String?     @map("address_country") @db.VarChar(255)
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  // Relations
  cartItems      CartItem[]
  orders         Order[]
  reviews        Review[]
  wishlist       Wishlist[]
  sessions       Session[]
  passkeys       Passkey[]

  @@map("users")
}

// Category model - Product categories
model Category {
  id          Int       @id @default(autoincrement())
  name        String    @db.VarChar(255)
  description String?   @db.Text
  status      String    @default("active") @db.VarChar(20)
  createdAt   DateTime? @map("created_at") @db.Date

  // Relations
  products    Product[]

  @@map("categories")
}

// Product model - Items for sale
model Product {
  id             Int       @id @default(autoincrement())
  name           String    @db.VarChar(255)
  description    String?   @db.Text
  price          Decimal   @db.Decimal(10, 2)
  originalPrice  Decimal?  @map("original_price") @db.Decimal(10, 2)
  thumbnail      String?   @db.VarChar(255)
  stock          Int       @default(0)
  categoryId     Int?      @map("category_id")
  averageRating  Decimal   @default(0) @map("average_rating") @db.Decimal(3, 2)
  reviewCount    Int       @default(0) @map("review_count")
  isFeatured     Boolean   @default(false) @map("is_featured")
  isOnSale       Boolean   @default(false) @map("is_on_sale")
  isNewArrival   Boolean   @default(false) @map("is_new_arrival")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  // Relations
  category       Category?      @relation(fields: [categoryId], references: [id])
  cartItems      CartItem[]
  orderDetails   OrderDetail[]
  reviews        Review[]
  images         ProductImage[]
  wishlist       Wishlist[]

  @@map("products")
}

// CartItem model - Shopping cart items
model CartItem {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  productId Int      @map("product_id")
  quantity  Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("cart_items")
}

// Order model - Customer orders
model Order {
  id         Int       @id @default(autoincrement())
  userId     Int?      @map("user_id")
  orderCode  String    @unique @map("order_code") @db.VarChar(255)
  note       String?   @db.Text
  status     String    @default("pending") @db.VarChar(100)
  subtotal   Decimal?  @db.Decimal(10, 2)
  taxFee     Decimal?  @map("tax_fee") @db.Decimal(10, 2)
  total      Decimal?  @db.Decimal(10, 2)
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  // Relations
  user         User?          @relation(fields: [userId], references: [id])
  orderDetails OrderDetail[]

  @@map("orders")
}

// OrderDetail model - Items in each order
model OrderDetail {
  id        Int      @id @default(autoincrement())
  orderId   Int?     @map("order_id")
  productId Int?     @map("product_id")
  price     Decimal? @db.Decimal(10, 2)
  quantity  Int?
  subtotal  Decimal? @db.Decimal(10, 2)

  // Relations
  order     Order?   @relation(fields: [orderId], references: [id])
  product   Product? @relation(fields: [productId], references: [id])

  @@map("order_details")
}

// Review model - Product reviews
model Review {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  productId Int      @map("product_id")
  rating    Int      @db.SmallInt
  comment   String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("reviews")
}

// ProductImage model - Additional product images
model ProductImage {
  id        Int     @id @default(autoincrement())
  imageUrl  String  @map("image_url") @db.VarChar(255)
  productId Int?    @map("product_id")

  // Relations
  product   Product? @relation(fields: [productId], references: [id])

  @@map("product_images")
}

// Wishlist model - User's saved products
model Wishlist {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  productId Int      @map("product_id")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("wishlist")
}

// ==================== SESSION HIJACKING MVP MODELS ====================

// Session model – JWT-based session management
model Session {
  id               Int       @id @default(autoincrement())
  sessionId        String    @unique @map("session_id") @db.VarChar(128)
  userId           Int       @map("user_id")
  tokenHash        String    @map("token_hash") @db.VarChar(255)
  rotationEnabled  Boolean   @default(true) @map("rotation_enabled")
  expiresAt        DateTime  @map("expires_at")
  revokedAt        DateTime? @map("revoked_at")
  revokeReason     String?   @map("revoke_reason") @db.VarChar(255)
  ipBucket         String?   @map("ip_bucket") @db.VarChar(64)
  uaBucket         String?   @map("ua_bucket") @db.VarChar(64)
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  // Relations
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  events           SessionEvent[]
  auditLogs        AuditLog[]

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

// SessionEvent model – event log theo session (non-PII)
model SessionEvent {
  id           Int      @id @default(autoincrement())
  sessionId    String   @map("session_id") @db.VarChar(128)
  eventType    String   @map("event_type") @db.VarChar(64)
  eventTypeId  Int      @default(0) @map("event_type_id")
  deltaT_ms    Int      @default(0) @map("delta_t_ms")
  flags        Json     @default("{}")
  metrics      Json     @default("{}")
  config       Json     @default("{}")
  ts           DateTime @default(now())

  // Relations
  session      Session  @relation(fields: [sessionId], references: [sessionId], onDelete: Cascade)

  @@index([sessionId])
  @@index([ts])
  @@index([eventType])
  @@map("session_events")
}

// AuditLog model – audit trail cho mọi hành động policy
model AuditLog {
  id          Int      @id @default(autoincrement())
  sessionId   String   @map("session_id") @db.VarChar(128)
  action      String   @db.VarChar(32)   // WARN | STEP_UP | REVOKE | TOKEN_ROTATE
  reason      String?  @db.Text
  anomalyScore Float?  @map("anomaly_score")
  riskEma     Float?   @map("risk_ema")
  ts          DateTime @default(now())

  // Relations
  session     Session  @relation(fields: [sessionId], references: [sessionId], onDelete: Cascade)

  @@index([sessionId])
  @@index([ts])
  @@map("audit_logs")
}

// ==================== PASSKEY / WEBAUTHN ====================

// Passkey model – WebAuthn credentials (1 user có thể có nhiều passkeys)
model Passkey {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  // credentialId: raw bytes từ WebAuthn authenticator (unique)
  credentialId Bytes    @unique @map("credential_id")
  // publicKey: COSE-encoded public key (bytes)
  publicKey    Bytes    @map("public_key")
  // counter: số lần ký (dùng để phát hiện replay attacks)
  counter      BigInt   @default(0)
  // transports: danh sách transport hints (json array: "ble", "internal", "nfc", "usb")
  transports   String?  @db.VarChar(255)
  // Tên thân thiện do user đặt (tuỳ chọn)
  name         String?  @db.VarChar(100)
  createdAt    DateTime @default(now()) @map("created_at")

  // Relations
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("passkeys")
}
